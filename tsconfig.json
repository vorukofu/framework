{
  "compilerOptions": {
    "target": "es6",
    "module": "esnext",
    "rootDir": "packages",
    "outDir": "./build",
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
  }
}
